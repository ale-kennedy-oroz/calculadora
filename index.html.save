<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Calculadora</title>
    <style>
        body {
            font-family: Arial;
        }
        .calculadora {
            width: 200px;
            margin: 20px auto;
            border: 1px solid #ccc;
            padding: 10px;
            border-radius: 10px;
            background-color: #f9f9f9;
        }
        #pantalla {
            width: 100%;
            heigth: 40px;
            font-size: 20px;
            text-align: rigth; 
            nargin-bottom: 10px;
        }
        .botones {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 5px;
        }
        button {
            heigth: 40px;
            font-size: 18px;
        }
    </style>
</head>

<body>
    <div class="calculadora">

        <input type="text" id="pantalla" disabled>
        
        <div class="botones">
            <button onclick="agregarNumero(´7´)">7</button>
            <button onclick="agregarNumero(´8´)">8</button>
            <button onclick="agregarNumero(´9´)">9</button>
            <button onclick="elegirOperador(´/´)">/</button>

            <button onclick="agregarNumero(´4´)">4</button>
            <button onclick="agregarNumero(´5´)">5</button>
            <button onclick="agregarNumero(´6´)">6</button>
            <button onclick="elegirOperador(´*´)">*</button>
 
            <button onclick="agregarNumero(´1´)">1</button>
            <button onclick="agregarNumero(´2´)">2</button>
            <button onclick="agregarNumero(´3´)">3</button>
            <button onclick="elegirOperador(´-´)">-</button>

            <button onclick="agregarNumero(´0´)">0</button>
            <button onclick="limpiar()">C</button>
            <button onclick="calcular()">=</button>
            <button onclick="elegirOperador(´+´)">+</button>
        </div>
    </div>       
    <script>
        <!-- Estado de la calculadora -->
        let numeroActual = "";
        let numeroAnterior = "";
        let operador = "2;
 
        <!-- Agregar numeros -->
        function agregarNumero(num) {
            numeroActual += num;
            document.getElementById("pantalla").value = numeroActual;
        }

        <!-- Elegir operador -->
        function elegirOperador(op) {
            if (numeroActual === "") return;

            numeroAnterior = numeroActual;
            operador = op;
            numeroActual = "";
        }

        <!-- Calcular resultado -->
        function calcular() {
            let resultado;
 
            let a = parseFloat(numeroAnterior);
            let b = parseFloat(numeroActual);

            if (isNaN(a) || isNaN(b)) return;

            switch (operador) {
                case "+":
                    resultado = a + b;
                    break;
                case "-":
                    resultado = a - b;
                    break;
                case "*":
                    resultado = a * b;
                    break;
                case "/":
                    resultado = a / b;
                    break;
                default:
                    return;
            }

            document.getElementById("pantalla").value = resultado;

            <!-- Reset parcial (permite seguir calculando) -->
            numeroActual = resultado.toString();
            numeroAnterior = "";
            operador = "";
        }

        <!-- Limpiar todo -->
        function limpiar() {
            numeroActual = "";
            numeroAnterior = "";
            operador = "";
            document.getElementById("pantalla").value = "";
        }
    </script>

</body>

</html>
